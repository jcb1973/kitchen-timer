# kitchen-timer / timerd config + secrets.
# Copy to .creds (INI, gitignored, chmod 600). All keys optional; defaults in config.py.

[matrix]
url   = http://127.0.0.1:8081
token = REPLACE_WITH_MATRIX_TOKEN

[buzzer]
# buzzerd is not built yet. Leave url empty -> beeps are stubbed (logged, silent).
# When buzzerd lands, set its url + token here and the beep at zero starts working;
# no code changes needed.
url   =
token =

[timer]
listen_host  = 127.0.0.1
listen_port  = 8083
token        =
default_set_s = 300
screen_ttl   = 30
